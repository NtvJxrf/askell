{
  "name": "askell",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "bcrypt": "^6.0.0",
    "googleapis": "^173.0.0",
    "got": "^15.0.5",
    "iovalkey": "^0.3.3"
  },
  "scripts": {
    "dev": "pm2 start ecosystem.config.cjs",
    "front": "cd apps/frontend && npm run dev",
    "front build": "cd apps/frontend && npm run build",
    "signoz:setup": "node observability/setup-signoz.mjs",
    "signoz:up": "docker-compose -p signoz -f signoz/deploy/docker/docker-compose.yaml up -d --remove-orphans",
    "signoz:down": "docker-compose -p signoz -f signoz/deploy/docker/docker-compose.yaml down",
    "db:generate": "pnpm --filter @askell/shared db:generate",
    "db:migrate": "pnpm --filter @askell/shared db:migrate",
    "db:push": "pnpm --filter @askell/shared db:push",
    "db:studio": "pnpm --filter @askell/shared db:studio",
    "seed": "node apps/backend/scripts/seed-admin.js",
    "test": "node ./apps/backend/test.js"
  }
}
